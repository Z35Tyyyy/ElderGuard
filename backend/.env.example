# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/elderguard?retryWrites=true&w=majority

# JWT Secret (use a strong random string in production)
JWT_SECRET=your_jwt_secret_here_change_in_production

# Server Port
PORT=5000

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:3000

# Email Configuration (use Ethereal for dev, or real SMTP for prod)
# Leave empty to auto-generate Ethereal test account
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Transaction threshold (in INR) — transactions above this require guardian approval
TXN_THRESHOLD=5000
